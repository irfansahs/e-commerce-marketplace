# SQL Server (local dev)
ACCEPT_EULA=Y
MSSQL_SA_PASSWORD=Marketplace_Local1!
# Host port mapped to container 1433 (14330 avoids clash with Windows SQL Server on 1433)
MSSQL_HOST_PORT=14330
# Service databases (created by mssql-init): identity_db, catalog_db, cart_order_db, inventory_db, payment_db, notification_db
# Host: localhost,14330  User: sa
# Identity (dotnet run): MSSQL_SA_PASSWORD in launchSettings or shell — must match Docker volume password

# RabbitMQ
RABBITMQ_DEFAULT_USER=marketplace
RABBITMQ_DEFAULT_PASS=change_me_local_only

# Redis (no auth in local dev by default)
REDIS_HOST=redis
REDIS_PORT=6379

# Next.js web (Docker service `web` — browser uses http://localhost:8080 only)
# INTERNAL_API_URL is set in docker-compose.yml for the web container (gateway DNS)
# COOKIE_SECURE=true behind HTTPS; local compose uses false

# Graylog (profile observability — local only)
# Secret ≥16 chars; root password hash = SHA256 of your admin password (see infra/graylog/README.md)
GRAYLOG_PASSWORD_SECRET=change_me_graylog_secret_min16
# Default hash below = password "admin" (dev only)
GRAYLOG_ROOT_PASSWORD_SHA2=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918
