{
  "Routes": [
    {
      "Key": "identity-health",
      "DownstreamPathTemplate": "/health",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [{ "Host": "identity-api", "Port": 8080 }],
      "UpstreamPathTemplate": "/api/identity/health",
      "UpstreamHttpMethod": [ "GET" ],
      "Priority": 3,
      "RouteIsCaseSensitive": false
    },
    {
      "Key": "identity-register",
      "DownstreamPathTemplate": "/auth/register",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [{ "Host": "identity-api", "Port": 8080 }],
      "UpstreamPathTemplate": "/api/identity/auth/register",
      "UpstreamHttpMethod": [ "POST" ],
      "Priority": 3,
      "RouteIsCaseSensitive": false
    },
    {
      "Key": "identity-login",
      "DownstreamPathTemplate": "/auth/login",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [{ "Host": "identity-api", "Port": 8080 }],
      "UpstreamPathTemplate": "/api/identity/auth/login",
      "UpstreamHttpMethod": [ "POST" ],
      "Priority": 3,
      "RouteIsCaseSensitive": false
    },
    {
      "Key": "identity-api",
      "DownstreamPathTemplate": "/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [{ "Host": "identity-api", "Port": 8080 }],
      "UpstreamPathTemplate": "/api/identity/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS" ],
      "Priority": 0,
      "RouteIsCaseSensitive": false,
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      }
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://gateway-api:8080"
  }
}
