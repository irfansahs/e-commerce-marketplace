@baseUrl = http://localhost:8080
@token = 

### Register
POST {{baseUrl}}/api/identity/auth/register
Content-Type: application/json
Accept-Language: tr

{
  "email": "buyer@test.com",
  "password": "Test1234!"
}

### Login
# @name login
POST {{baseUrl}}/api/identity/auth/login
Content-Type: application/json

{
  "email": "buyer@test.com",
  "password": "Test1234!"
}

### Me
GET {{baseUrl}}/api/identity/auth/me
Authorization: Bearer {{login.response.body.accessToken}}

### Health (via Nginx + Gateway)
GET {{baseUrl}}/api/identity/health
